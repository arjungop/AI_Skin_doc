# Backend configuration

# Azure SQL connection string for SQLAlchemy + pyodbc
# Example:
# mssql+pyodbc://<user>:<password>@<server>.database.windows.net:1433/<db>?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
AZURE_SQL_CONNECTION_STRING=

# CORS allowed origin for frontend (e.g., https://your-frontend.azurestaticapps.net)
FRONTEND_ORIGIN=

# Skin disease ML model (ConvNeXt-Large, 20-class)
# Copy checkpoints/best_model.pth from the training server to backend/ml/weights/
LESION_MODEL_WEIGHTS=backend/ml/weights/best_model.pth
# Input size must match training (384)
LESION_IMG_SIZE=384

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=lesion-images

# Optional Azure AD configuration (if using Entra ID)
# TENANT_ID=
# CLIENT_ID=
# API_AUDIENCE=

# Azure OpenAI (for LLM chat/diagnosis)
# API version default: 2024-05-01-preview
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# OpenAI (non-Azure) fallback
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama local fallback
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b
# Database configuration
# Preferred: a full SQLAlchemy URL
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# For MySQL, either set DATABASE_URL directly or use the MYSQL_* helpers below:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DB=ai_doc
# MYSQL_USER=appuser
# MYSQL_PASSWORD=secret
